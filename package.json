{
  "name": "agent-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "preview": "astro preview",
    "configure": "node scripts/configure-blog.mjs",
    "install:claude-code": "node scripts/install-claude-code.mjs",
    "install:codex": "node scripts/install-codex.mjs",
    "install:hermes": "node scripts/install-hermes.mjs",
    "install:pi": "node scripts/install-pi.mjs",
    "test": "npm run test:themes && astro build && vitest run",
    "test:themes": "node scripts/verify-themes.mjs",
    "test:watch": "vitest",
    "review": "node scripts/review.mjs",
    "review:manual": "node scripts/review.mjs manual",
    "review:fixture": "node scripts/review.mjs fixture --fixture test/fixtures/gateway-day.json --draft test/fixtures/review-draft.json --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.217",
    "@astrojs/rss": "^4.0.19",
    "@earendil-works/pi-coding-agent": "0.81.1",
    "astro": "^7.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  }
}
