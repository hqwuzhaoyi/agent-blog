---
import { siteConfig } from "@/site.config";
import { sitePath } from "@/lib/paths";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  pageClass = "",
} = Astro.props;
const pageTitle = title === siteConfig.title ? title : `${title} — ${siteConfig.title}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f05a28" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={sitePath("favicon.svg")} />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.title} RSS`} href={sitePath("rss.xml")} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <title>{pageTitle}</title>
  </head>
  <body class={pageClass}>
    <div class="page-shell">
      <header class="site-header">
        <a class="wordmark" href={sitePath()} aria-label={`${siteConfig.title} home`}>
          <span class="wordmark__signal" aria-hidden="true"></span>
          <span>
            <strong>{siteConfig.title}</strong>
            <small>{siteConfig.eyebrow}</small>
          </span>
        </a>
        <nav aria-label="Primary navigation">
          <a href={sitePath()}>Latest</a>
          <a href={sitePath("archive/")}>Archive</a>
          <a href={sitePath("rss.xml")}>RSS</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div>
          <span class="status-light" aria-hidden="true"></span>
          <span>Reporting from {siteConfig.sourceLabel}</span>
        </div>
        <p>Reported outcomes, reviewed by a human before publication.</p>
      </footer>
    </div>
  </body>
</html>
