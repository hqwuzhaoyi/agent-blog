---
import { activeTheme, siteConfig } from "@/site.config";
import { sitePath } from "@/lib/paths";
import type { FooterProps, HeaderProps } from "@/themes/shared/contracts";

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  pageClass = "",
} = Astro.props;
const pageTitle = title === siteConfig.title ? title : `${title} — ${siteConfig.title}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ThemeHeader = activeTheme.slots.Header;
const ThemeFooter = activeTheme.slots.Footer;
const headerProps: HeaderProps = {
  title: siteConfig.title,
  eyebrow: siteConfig.eyebrow,
  homeUrl: sitePath(),
  navigationLabel: siteConfig.nav.label,
  navigation: [
    { label: siteConfig.nav.latest, url: sitePath() },
    { label: siteConfig.nav.archive, url: sitePath("archive/") },
    { label: siteConfig.nav.rss, url: sitePath("rss.xml") },
  ],
};
const footerProps: FooterProps = {
  source: siteConfig.sourceLabel,
  reportingLabel: siteConfig.footer.reporting,
  disclaimer: siteConfig.footer.disclaimer,
};
---

<!doctype html>
<html lang={siteConfig.language} data-theme={siteConfig.theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content={activeTheme.themeColor} />
    <link rel="stylesheet" href={activeTheme.stylesheet} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={sitePath("favicon.svg")} />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.title} RSS`} href={sitePath("rss.xml")} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <title>{pageTitle}</title>
  </head>
  <body class={pageClass}>
    <div class="page-shell">
      <ThemeHeader {...headerProps} />
      <main>
        <slot />
      </main>
      <ThemeFooter {...footerProps} />
    </div>
  </body>
</html>
