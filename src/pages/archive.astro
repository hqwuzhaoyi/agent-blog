---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedReviews } from "@/lib/reviews";
import { presentReview } from "@/lib/presentation";
import { activeTheme, siteConfig } from "@/site.config";
import type { ArchiveListProps } from "@/themes/shared/contracts";

const reviews = (await getPublishedReviews()).map((review) => presentReview(review, siteConfig.locale));
const ArchiveList = activeTheme.slots.ArchiveList;
const archiveListProps: ArchiveListProps = {
  reviews,
  labels: {
    kicker: siteConfig.archive.kicker,
    title: siteConfig.archive.title,
    summary: siteConfig.archive.summary(reviews.length),
    publishedReviews: siteConfig.archive.publishedReviews,
    signals: siteConfig.review.signals,
  },
};
---

<BaseLayout title={siteConfig.archive.title} description={siteConfig.archive.description}>
  <ArchiveList {...archiveListProps} />
</BaseLayout>
