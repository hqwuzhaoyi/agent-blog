---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedReviews } from "@/lib/reviews";
import { presentReview } from "@/lib/presentation";
import { activeTheme, siteConfig } from "@/site.config";
import { sitePath } from "@/lib/paths";
import type { BlogIntroProps, ReviewListProps } from "@/themes/shared/contracts";

const reviews = (await getPublishedReviews()).map((review) => presentReview(review, siteConfig.locale));
const [latest, ...previous] = reviews;
const BlogIntro = activeTheme.slots.BlogIntro;
const ReviewList = activeTheme.slots.ReviewList;
const blogIntroProps: BlogIntroProps = {
  eyebrow: siteConfig.eyebrow,
  title: siteConfig.title,
  tagline: siteConfig.tagline,
  publishedCount: reviews.length,
  latestDate: latest?.displayDate,
  labels: {
    published: siteConfig.home.published,
    updated: siteConfig.home.updated,
  },
};
const reviewListProps: ReviewListProps = {
  latest,
  previous: previous.slice(0, 4),
  labels: { ...siteConfig.home, ...siteConfig.review },
  archiveUrl: sitePath("archive/"),
};
---

<BaseLayout>
  <BlogIntro {...blogIntroProps} />
  <ReviewList {...reviewListProps} />
</BaseLayout>
