---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedReviews } from "@/lib/reviews";
import { presentReview } from "@/lib/presentation";
import { activeTheme, siteConfig } from "@/site.config";
import { sitePath } from "@/lib/paths";
import type { HomeHeroProps, ReviewListProps } from "@/themes/shared/contracts";

const reviews = (await getPublishedReviews()).map((review) => presentReview(review, siteConfig.locale));
const [latest, ...previous] = reviews;
const HomeHero = activeTheme.slots.HomeHero;
const ReviewList = activeTheme.slots.ReviewList;
const heroProps: HomeHeroProps = {
  description: siteConfig.description,
  kicker: siteConfig.home.kicker,
  heading: siteConfig.home.heading,
  headingEmphasis: siteConfig.home.headingEmphasis,
  policyLabel: siteConfig.home.policyLabel,
  note: siteConfig.home.note,
  policy: siteConfig.home.policy,
  facts: [
    { label: siteConfig.home.input, value: siteConfig.home.inputValue },
    { label: siteConfig.home.filter, value: siteConfig.home.filterValue },
    { label: siteConfig.home.gate, value: siteConfig.home.gateValue },
  ],
  ticker: siteConfig.home.ticker,
};
const reviewListProps: ReviewListProps = {
  latest,
  previous: previous.slice(0, 4),
  labels: { ...siteConfig.home, ...siteConfig.review },
  archiveUrl: sitePath("archive/"),
};
---

<BaseLayout>
  <HomeHero {...heroProps} />
  <ReviewList {...reviewListProps} />
</BaseLayout>
