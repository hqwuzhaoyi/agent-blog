---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { presentReview } from "@/lib/presentation";
import { sitePath } from "@/lib/paths";
import { activeTheme, siteConfig } from "@/site.config";
import type { ReviewArticleProps } from "@/themes/shared/contracts";

export async function getStaticPaths() {
  const reviews = await getCollection("reviews");
  return reviews.map((review) => ({ params: { id: review.id }, props: { review } }));
}

const { review } = Astro.props;
const { Content } = await render(review);
const presentedReview = presentReview(review, siteConfig.locale);
const ReviewArticle = activeTheme.slots.ReviewArticle;
const reviewArticleProps: ReviewArticleProps = {
  review: presentedReview,
  Content,
  labels: siteConfig.review,
  homeUrl: sitePath(),
  archiveUrl: sitePath("archive/"),
};
---

<BaseLayout title={review.data.title} description={review.data.summary} pageClass="review-page">
  <ReviewArticle {...reviewArticleProps} />
</BaseLayout>
