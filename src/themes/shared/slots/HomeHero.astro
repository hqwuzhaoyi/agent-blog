---
import type { HomeHeroProps } from "../contracts";

interface Props extends HomeHeroProps {}

const { description, kicker, heading, headingEmphasis, policyLabel, note, policy, facts, ticker } = Astro.props;
---

<section class="hero">
  <div class="hero__copy">
    {kicker && <p class="kicker"><span>01</span> {kicker}</p>}
    <h1>
      {heading}
      {headingEmphasis && <><br /><em>{headingEmphasis}</em></>}
    </h1>
    <p class="hero__lede">{description}</p>
  </div>
  <aside class="hero__manifesto" aria-label={policyLabel}>
    <span class="manifesto__index">{note}</span>
    <p>{policy}</p>
    <dl>
      {facts.map((fact) => <div><dt>{fact.label}</dt><dd>{fact.value}</dd></div>)}
    </dl>
  </aside>
</section>

<section class="ticker" aria-label={policyLabel}>
  {ticker.map((item, index) => <><span>{item}</span>{index < ticker.length - 1 && <i></i>}</>)}
</section>
