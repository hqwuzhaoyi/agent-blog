---
import type { ReviewArticleProps } from "../contracts";

interface Props extends ReviewArticleProps {}

const { review, Content, labels, homeUrl, archiveUrl } = Astro.props;
---

<article class="review-article">
  <header class="review-article__header">
    <a class="back-link" href={homeUrl} aria-label={labels.back}>← {labels.latest}</a>
    <div class="review-article__stamp">
      <span>{labels.daily}</span>
      <b>{review.highlights}</b>
      <small>{labels.signals}</small>
    </div>
    <div class="review-article__heading">
      <p class="kicker"><span>{labels.report}</span> {review.source}</p>
      <h1>{review.title}</h1>
      <p>{review.summary}</p>
    </div>
    <dl class="review-article__meta">
      <div><dt>{labels.day}</dt><dd>{review.displayDate}</dd></div>
      <div><dt>{labels.source}</dt><dd>{review.platforms}</dd></div>
      <div><dt>{labels.status}</dt><dd><span class="status-light"></span> {labels.approved}</dd></div>
    </dl>
  </header>
  <div class="prose"><Content /></div>
  <footer class="review-article__footer">
    <p>{labels.disclaimer}</p>
    <a href={archiveUrl}>{labels.continue}</a>
  </footer>
</article>
