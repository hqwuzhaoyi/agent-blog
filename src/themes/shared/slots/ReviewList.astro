---
import ReviewCard from "./ReviewCard.astro";
import type { ReviewListProps } from "../contracts";

interface Props extends ReviewListProps {}

const { latest, previous, labels, archiveUrl } = Astro.props;
const cardLabels = { read: labels.read, open: labels.open, signals: labels.signals };
---

{latest ? (
  <section class="latest-section">
    <div class="section-heading">
      <p>{labels.latest}</p>
      <span>{labels.reviewed}</span>
    </div>
    <ReviewCard review={latest} featured labels={cardLabels} />
  </section>
) : (
  <section class="empty-state">
    <p>{labels.configured}</p>
    <h2>{labels.empty}</h2>
  </section>
)}

{previous.length > 0 && (
  <section class="previous-section">
    <div class="section-heading">
      <p>{labels.previous}</p>
      <a href={archiveUrl}>{labels.fullArchive}</a>
    </div>
    <div class="review-grid">
      {previous.map((review, index) => <ReviewCard review={review} index={index} labels={cardLabels} />)}
    </div>
  </section>
)}
